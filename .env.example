# ── Securix Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in your values for local development.
# NEVER commit .env to version control.

# Flask secret key — generate a strong random string for production.
# You can generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# ==========================================
# External Service API Keys
# ==========================================

# VirusTotal API Key for real-time URL and file reputation scanning.
# Get a free key at: https://www.virustotal.com/gui/join-us
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# Groq API Key for the Securix AI Chatbot and Phishing Simulator.
# Get a free key at: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# ==========================================
# Cloudflare Radar API
# ==========================================
# Get a free API token at: https://dash.cloudflare.com/ → API Tokens → Create Token
# Use the "Edit Cloudflare Radar" template or create a custom token with "Account > Radar > Read" permissions
CLOUDFLARE_RADAR_TOKEN=your_cloudflare_radar_token_here

# ==========================================
# Google Safe Browsing API
# ==========================================
# Get a free API key at: https://console.cloud.google.com/ → APIs & Services → Library
# Search for "Safe Browsing API", enable it, then create credentials (API key)
GOOGLE_SAFEBROWSING_KEY=your_google_safebrowsing_key_here

# ==========================================
# AbuseIPDB API
# ==========================================
# Get a free API key at: https://www.abuseipdb.com/ → Register → API
ABUSEIPDB_KEY=your_abuseipdb_key_here

# ==========================================
# HaveIBeenPwned API (Email Breach Checking)
# ==========================================
# Get a paid API key at: https://haveibeenpwned.com/API/Key ($3.50/month)
# Required for email breach checking. Password breach checking works without it (uses k-anonymity).
HIBP_API_KEY=your_hibp_api_key_here

# ==========================================
# NumLookup API (Phone Carrier Enrichment)
# ==========================================
# Get a free API key at: https://numlookupapi.com/register (100 free requests/month)
# Optional — enhances carrier, line type, and location data for phone scans.
NUMLOOKUP_API_KEY=your_numlookup_api_key_here

# ==========================================
# Google OAuth 2.0 (Sign in with Google)
# ==========================================
# Get OAuth credentials at: https://console.cloud.google.com/
# Authorized redirect URI: <your-domain>/authorize/google
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ==========================================
# Admin Panel
# ==========================================
# Set this to the username of the user who should have admin access.
# The admin panel is accessible at /admin/ and allows managing users,
# malware signatures, badges, phishing stats, and chat conversations.
ADMIN_USERNAME=admin
